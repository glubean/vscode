{
  "name": "glubean",
  "displayName": "Glubean — REST Client & API Test Runner",
  "description": "Code-first API test runner and REST client for TypeScript. Explore APIs, run tests, debug with breakpoints, and see traces — Postman alternative powered by AI.",
  "version": "0.17.28",
  "publisher": "Glubean",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/glubean/vscode"
  },
  "bugs": {
    "url": "https://github.com/glubean/vscode/issues"
  },
  "homepage": "https://github.com/glubean/vscode#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "keywords": [
    "glubean",
    "rest-client",
    "api-client",
    "http-client",
    "api-testing",
    "api-test",
    "test-runner",
    "postman",
    "postman-alternative",
    "thunder-client",
    "rest-api",
    "api-explorer",
    "http",
    "openapi-testing",
    "swagger-testing",
    "integration-testing",
    "endpoint-testing",
    "api-automation",
    "backend-testing",
    "contract-testing",
    "typescript",
    "code-first",
    "ai-testing"
  ],
  "qna": "marketplace",
  "galleryBanner": {
    "color": "#1a1a1a",
    "theme": "dark"
  },
  "activationEvents": [
    "workspaceContains:**/*.test.ts",
    "workspaceContains:**/*.test.js",
    "workspaceContains:**/*.test.mjs",
    "onLanguage:typescript",
    "onLanguage:javascript"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "test": [
        {
          "id": "glubean.tasksView",
          "name": "Glubean"
        }
      ]
    },
    "configuration": {
      "title": "Glubean",
      "properties": {
        "glubean.autoDiscover": {
          "type": "boolean",
          "default": true,
          "description": "Automatically discover tests when files are opened or changed"
        },
        "glubean.resultHistoryLimit": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "maximum": 100,
          "description": "Max result files to keep per test (older results are auto-deleted)"
        },
        "glubean.telemetry.enabled": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Share anonymous usage data (run counts, errors, feature usage) to help improve Glubean. No code, file paths, or personal data is ever collected. [Learn what's collected](https://github.com/glubean/vscode/blob/main/docs/telemetry.md)"
        },
        "glubean.testExplorerLayout": {
          "type": "string",
          "enum": [
            "flat",
            "tree",
            "auto"
          ],
          "default": "auto",
          "description": "Test Explorer layout: 'flat' (files only), 'tree' (directory hierarchy), 'auto' (flat when ≤15 files, tree when >15)"
        },
        "glubean.taskTimeoutMs": {
          "type": "number",
          "default": 300000,
          "minimum": 10000,
          "description": "Milliseconds to wait for a task to produce results before marking it as timed out (default: 5 minutes)"
        },
        "glubean.openResultAfterTask": {
          "type": "string",
          "default": "always",
          "enum": [
            "always",
            "failures",
            "never"
          ],
          "enumDescriptions": [
            "Open the result viewer after every task run",
            "Open the result viewer only when tests fail",
            "Never auto-open the result viewer"
          ],
          "description": "When to automatically open the result viewer after a task panel run completes"
        }
      }
    },
    "snippets": [
      {
        "language": "typescript",
        "path": "./snippets/glubean-typescript.json"
      },
      {
        "language": "javascript",
        "path": "./snippets/glubean-javascript.json"
      }
    ],
    "commands": [
      {
        "command": "glubean.runFile",
        "title": "Glubean: Run All Tests in File",
        "icon": "$(play)"
      },
      {
        "command": "glubean.runProject",
        "title": "Glubean: Run All Tests in Project",
        "icon": "$(run-all)"
      },
      {
        "command": "glubean.openLastResult",
        "title": "Glubean: Open Last Result JSON"
      },
      {
        "command": "glubean.checkDependencies",
        "title": "Glubean: Setup"
      },
      {
        "command": "glubean.selectEnv",
        "title": "Glubean: Select Environment"
      },
      {
        "command": "glubean.rerunLast",
        "title": "Glubean: Re-run Last Request"
      },
      {
        "command": "glubean.diffPrevious",
        "title": "Glubean: Diff with Previous Run"
      },
      {
        "command": "glubean.copyAsCurl",
        "title": "Glubean: Copy as cURL"
      },
      {
        "command": "glubean.runPick",
        "title": "Glubean: Run Pick Example"
      },
      {
        "command": "glubean.initProject",
        "title": "Glubean: Initialize Project"
      },
      {
        "command": "glubean.cleanResults",
        "title": "Glubean: Clean All Results"
      },
      {
        "command": "glubean.openResult",
        "title": "Glubean: Open Latest Result"
      },
      {
        "command": "glubean.resultPrev",
        "title": "Glubean: Previous Result"
      },
      {
        "command": "glubean.resultNext",
        "title": "Glubean: Next Result"
      },
      {
        "command": "glubean.resultViewSource",
        "title": "View Source",
        "icon": "$(go-to-file)"
      },
      {
        "command": "glubean.resultViewRich",
        "title": "View as Result",
        "icon": "$(open-preview)"
      },
      {
        "command": "glubean.tasks.run",
        "title": "Run Task",
        "icon": "$(play)"
      },
      {
        "command": "glubean.tasks.runAll",
        "title": "Run All Tasks",
        "icon": "$(run-all)"
      },
      {
        "command": "glubean.tasks.refresh",
        "title": "Refresh Tasks",
        "icon": "$(refresh)"
      },
      {
        "command": "glubean.rerunFailed",
        "title": "Glubean: Rerun Failed Tests",
        "icon": "$(debug-restart)"
      },
      {
        "command": "glubean.diagnose",
        "title": "Glubean: Diagnose"
      },
      {
        "command": "glubean.aiRefactor",
        "title": "Glubean: Refactor"
      },
      {
        "command": "glubean.pinFile",
        "title": "Pin to Glubean",
        "icon": "$(pin)"
      },
      {
        "command": "glubean.unpinFile",
        "title": "Unpin",
        "icon": "$(close)"
      },
      {
        "command": "glubean.runPinnedFile",
        "title": "Run Pinned File",
        "icon": "$(play)"
      },
      {
        "command": "glubean.pinTest",
        "title": "Pin Test to Glubean",
        "icon": "$(pin)"
      },
      {
        "command": "glubean.unpinTest",
        "title": "Unpin Test",
        "icon": "$(close)"
      },
      {
        "command": "glubean.runPinnedTest",
        "title": "Run Pinned Test",
        "icon": "$(play)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "glubean.aiRefactor",
          "when": "false"
        }
      ],
      "editor/title/run": [
        {
          "command": "glubean.runFile",
          "when": "resourceFilename =~ /\\.(test|explore)\\.(ts|js|mjs)$/",
          "group": "navigation"
        },
        {
          "command": "glubean.resultViewSource",
          "when": "glubean.resultViewerActive",
          "group": "navigation"
        },
        {
          "command": "glubean.resultViewRich",
          "when": "!glubean.resultViewerActive && resourceFilename =~ /\\.result\\.json$/",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "glubean.runFile",
          "when": "resourceFilename =~ /\\.(test|explore)\\.(ts|js|mjs)$/",
          "group": "glubean@1"
        },
        {
          "command": "glubean.pinFile",
          "when": "resourceFilename =~ /\\.(test|explore)\\.(ts|js|mjs)$/",
          "group": "glubean@2"
        },
        {
          "command": "glubean.runProject",
          "when": "explorerResourceIsFolder && resourceFilename =~ /^(?!node_modules$|\\.git$|dist$).+$/",
          "group": "glubean@3"
        }
      ],
      "view/title": [
        {
          "command": "glubean.tasks.runAll",
          "when": "view == glubean.tasksView",
          "group": "navigation"
        },
        {
          "command": "glubean.tasks.refresh",
          "when": "view == glubean.tasksView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "glubean.tasks.run",
          "when": "view == glubean.tasksView && viewItem == glubeanTask",
          "group": "inline"
        },
        {
          "command": "glubean.runPinnedFile",
          "when": "view == glubean.tasksView && viewItem == pinnedFile",
          "group": "inline@1"
        },
        {
          "command": "glubean.unpinFile",
          "when": "view == glubean.tasksView && viewItem == pinnedFile",
          "group": "inline@2"
        },
        {
          "command": "glubean.runPinnedTest",
          "when": "view == glubean.tasksView && viewItem == pinnedTest",
          "group": "inline@1"
        },
        {
          "command": "glubean.unpinTest",
          "when": "view == glubean.tasksView && viewItem == pinnedTest",
          "group": "inline@2"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "glubean.resultViewer",
        "displayName": "Glubean Result Viewer",
        "selector": [
          {
            "filenamePattern": "*.result.json"
          }
        ],
        "priority": "default"
      }
    ],
    "keybindings": [
      {
        "command": "glubean.rerunLast",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "editorTextFocus"
      },
      {
        "command": "glubean.resultPrev",
        "key": "ctrl+alt+[",
        "mac": "cmd+alt+[",
        "when": "editorTextFocus && resourceExtname == .json"
      },
      {
        "command": "glubean.resultNext",
        "key": "ctrl+alt+]",
        "mac": "cmd+alt+]",
        "when": "editorTextFocus && resourceExtname == .json"
      },
      {
        "command": "glubean.runFile",
        "key": "ctrl+alt+t",
        "mac": "cmd+alt+t",
        "when": "editorTextFocus && resourceFilename =~ /\\.(test|explore)\\.(ts|js|mjs)$/"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run build:extension && npm run build:webview",
    "build:vendor": "node scripts/vendor-runner.mjs",
    "build:extension": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --external:@glubean/runner --format=cjs --platform=node --minify --sourcemap",
    "build:webview": "esbuild ./src/webview/index.tsx --bundle --outfile=dist/webview/index.js --format=iife --platform=browser --minify --sourcemap --jsx=automatic --jsx-import-source=preact && npx @tailwindcss/cli -i ./src/webview/styles.css -o ./dist/webview/styles.css -m",
    "watch": "concurrently \"npm:watch:*\"",
    "watch:extension": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --external:@glubean/runner --format=cjs --platform=node --watch --sourcemap",
    "watch:webview": "esbuild ./src/webview/index.tsx --bundle --outfile=dist/webview/index.js --format=iife --platform=browser --watch --sourcemap --jsx=automatic --jsx-import-source=preact",
    "watch:css": "npx @tailwindcss/cli -i ./src/webview/styles.css -o ./dist/webview/styles.css -w",
    "lint": "npm run lint:types && npm run lint:eslint",
    "lint:types": "tsc --noEmit",
    "lint:eslint": "eslint \"src/**/*.ts\"",
    "package": "npx @vscode/vsce package --no-dependencies",
    "publish": "npx @vscode/vsce publish",
    "install:vscode": "npm install && npm run package -- --out glubean.vsix && code --install-extension glubean.vsix",
    "install:cursor": "npm install && npm run package -- --out glubean.vsix && cursor --install-extension glubean.vsix"
  },
  "devDependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.12.1",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.15",
    "@lezer/highlight": "^1.2.3",
    "@tailwindcss/cli": "^4.2.0",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.24.0",
    "eslint": "^10.0.0",
    "preact": "^10.28.4",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@glubean/runner": "^0.1.46",
    "@glubean/scanner": "^0.1.32",
    "posthog-node": "^5.24.17",
    "yaml": "^2.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
